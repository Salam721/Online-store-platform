[Unit]
Description=Inventory WebSocket API Service
After=network.target

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/app
ExecStart=/home/ec2-user/venv/bin/gunicorn -w 4 -b 0.0.0.0:5000 app:app
Restart=always
RestartSec=3
Environment=PRODUCTS_TABLE=Products
Environment=AWS_REGION=us-east-1

[Install]
WantedBy=multi-user.target
